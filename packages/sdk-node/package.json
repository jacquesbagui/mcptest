{
  "name": "mcptest",
  "version": "0.1.0",
  "description": "Contract testing for MCP servers — TypeScript SDK.",
  "keywords": ["mcp", "model-context-protocol", "testing", "contract", "typescript", "sdk"],
  "author": "Jacques Bagui <jacques.bagui@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/jacquesbagui/mcptest",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jacquesbagui/mcptest.git",
    "directory": "packages/sdk-node"
  },
  "bugs": "https://github.com/jacquesbagui/mcptest/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ajv": "^8.17.1",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "eslint": "^9.10.0",
    "tsup": "^8.2.4",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
